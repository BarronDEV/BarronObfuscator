# ============================================================
# Barron Obfuscator - .gitignore
# ============================================================

# ==================== Build Outputs ====================
build/
out/
target/
bin/
*.jar
*.class
*.war
*.ear

# ==================== IDE ====================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/

# Eclipse
.project
.classpath
.settings/
.factorypath

# NetBeans
nbproject/
nbbuild/
nbdist/
nb-configuration.xml

# ==================== Gradle ====================
.gradle/
gradle/wrapper/gradle-wrapper.jar

# ==================== Sensitive / Runtime Data ====================
# Database files
*.db
*.sqlite
*.sqlite3
licenses.db

# Configuration (may contain DB credentials, API keys)
config.json
application.properties
application.yml
*.properties
!gradle.properties

# Environment variables
.env
.env.*
!.env.example

# SSL Certificates
*.pem
*.crt
*.key
*.p12
*.jks
*.keystore

# ==================== Generated / User Data ====================
# Obfuscated plugin output
sifrelenmiş-pluginler/
encrypted-plugins/

# User upload directory
uploads/

# Grace period data (generated at runtime by protected plugins)
data.bin

# ==================== Logs ====================
*.log
logs/
startup.log
build_error.log
build_log.txt

# ==================== OS Files ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini
ehthumbs.db

# Linux
*~
.directory

# ==================== Backup / Temp ====================
*.bak
*.backup
*.tmp
*.swp
*.swo

# ==================== User Preferences ====================
*.prefs
user-preferences.json
